{
  "rules": {
    ".read": "auth != null && auth.token.email == 'dj@admin.com'",
    ".write": "auth != null && auth.token.email == 'dj@admin.com'",

    "support_chats": {
      ".read": "auth != null && auth.token.email == 'dj@admin.com'",
      ".write": "auth != null && auth.token.email == 'dj@admin.com'",
      "$uid": {
        "devices": {
          ".read": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')",
          ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')"
        },
        ".read": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')",
        ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')"
      }
    },

    // Configuración global accesible
    "config": {
      "plans": {
        ".read": "true",
        ".write": "false"
      },
      "public_payment_info": {
        ".read": "auth != null"
      },
      "admin_contact": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email == 'dj@admin.com'"
      }
    },

    // Registro público de eventos → mapea qué DJ es el dueño de cada evento
    "events_registry": {
      "$eventId": {
        ".read": "true",
        ".write": "auth != null && (!data.exists() || !data.hasChild('ownerUid') || data.child('ownerUid').val() == auth.uid || $eventId.contains(auth.uid) || auth.token.email == 'dj@admin.com') && ($eventId != 'default-event-RkgPXWAF32NsJUTCo4iBuNRsemC2' || newData.exists())"
      }
    },

    // Datos por usuario (arquitectura multi-usuario)
    "users": {
      // El administrador master puede listar/leer todas las cuentas de usuario
      ".read": "auth != null && auth.token.email == 'dj@admin.com'",
      ".write": "auth != null && auth.token.email == 'dj@admin.com'",
      
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')",
        ".write": "auth != null && ((auth.uid == $uid && !data.exists()) || auth.token.email == 'dj@admin.com')",
        "profile": {
          ".read": "true",
          ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')"
        },
        "events_index": {
          ".read": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')",
          "$eventId": {
            ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com') && ($eventId != 'default-event' || $uid != 'RkgPXWAF32NsJUTCo4iBuNRsemC2' || newData.exists())"
          }
        },
        "autocomplete_songs": {
          ".read": "true",
          ".write": "true",
          "$songId": {
            ".validate": "newData.hasChildren(['title', 'artist']) && (!data.exists() || (auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')))"
          }
        },
        "events": {
          ".read": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')",
          
          "$eventId": {
            ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com') && ($eventId != 'default-event' || $uid != 'RkgPXWAF32NsJUTCo4iBuNRsemC2' || newData.exists())",
            // El público general (sin estar autenticado) puede leer la configuración del evento
            "settings": {
              ".read": "true"
            },
            
            // El público general puede leer solicitudes y enviar/votar de forma anónima
            "requests": {
              ".read": "true",
              "$requestId": {
                ".write": "true",
                ".validate": "newData.hasChildren(['title', 'artist', 'timestamp', 'status'])"
              }
            },

            // El público general puede leer el historial de canciones ya reproducidas
            "played_requests": {
              ".read": "true"
            }
          }
        }
      }
    },

    // Suscripciones pendientes de validación
    "pending_subscriptions": {
      ".read": "auth != null && auth.token.email == 'dj@admin.com'",
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')",
        ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')"
      }
    },

    // Sugerencias de usuarios para mejorar la plataforma
    "suggestions": {
      ".read": "auth != null && auth.token.email == 'dj@admin.com'",
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')",
        ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'dj@admin.com')"
      }
    },

    // Rutas heredadas para mantener compatibilidad hacia atrás
    "events": {
      "$eventId": {
        ".write": "auth != null",
        "settings": {
          ".read": "true",
          ".write": "auth != null"
        },
        "requests": {
          ".read": "true",
          "$requestId": {
            ".write": "true",
            ".validate": "newData.hasChildren(['title', 'artist', 'timestamp', 'status'])"
          }
        },
        "played_requests": {
          ".read": "true"
        }
      }
    },
    "events_index": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "autocomplete_songs": {
      ".read": "true",
      ".write": "true"
    }
  }
}
